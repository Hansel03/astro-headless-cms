---
import type { Post } from "@pods/post-collection/post-collection.model";
import Header from "./components/header.astro";
import Body from "./components/body.astro";

interface Props {
  postEntry: Post;
}

const { postEntry } = Astro.props;
const likeCount = 6;
const postContent = {
  backButton: "Back to posts",
  published: "Published ",
  minRead: "min read",
};
---

<section class="flex shrink-1 grow flex-col gap-12 px-6 py-4">
  <Header
    gobackText={postContent.backButton}
    publishedText={postContent.published}
    date={postEntry.date}
  />
  <Body
    entry={postEntry}
    likeCount={likeCount}
    minReadText={postContent.minRead}
  />
</section>
